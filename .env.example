# ── WhatsApp ──
# El número de WhatsApp se configura en src/data/site.ts

# ── Google Calendar API (opcional) ──
# Solo necesario si quieres crear eventos directamente en el calendario de la clínica.
# Sin estas variables, el modal usa el modo "link directo" que abre Google Calendar del usuario.
#
# Instrucciones:
# 1. Ve a https://console.cloud.google.com
# 2. Crea un proyecto nuevo
# 3. Activa "Google Calendar API" en APIs & Services
# 4. Crea una Service Account en IAM & Admin → Service Accounts
# 5. Descarga la clave JSON de la Service Account
# 6. En Google Calendar, comparte el calendario con el email de la Service Account
#    (otórgale permisos de "Hacer cambios en eventos")
# 7. Completa las variables abajo con los datos de la clave JSON

GOOGLE_CALENDAR_ID=tucorreo@gmail.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=nombre@proyecto-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----"
