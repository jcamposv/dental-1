---
import Button from "../ui/Button.astro";
---

<section class="relative overflow-hidden bg-primary py-20 md:py-28">
  <!-- Decorative circles -->
  <div class="absolute top-0 left-0 -translate-x-1/2 -translate-y-1/2 h-64 w-64 rounded-full bg-white/5" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-0 translate-x-1/3 translate-y-1/3 h-80 w-80 rounded-full bg-white/5" aria-hidden="true"></div>

  <div class="container-narrow relative z-10 mx-auto px-5 text-center md:px-8 lg:px-16">
    <h2 class="font-heading text-3xl font-bold text-white md:text-4xl lg:text-5xl">
      Agenda Tu Cita Hoy
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">
      Da el primer paso hacia una sonrisa más saludable y brillante. Nuestro equipo está listo para recibirte.
    </p>
    <div class="mt-8">
      <Button variant="primary" href="#contact" size="lg" booking>
        Agendar Ahora
      </Button>
    </div>
  </div>
</section>
