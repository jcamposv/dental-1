---
interface Props {
  name: string;
  service: string;
  text: string;
  rating: number;
  image: string;
}

const { name, service, text, rating } = Astro.props;
---

<div class="rounded-2xl bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-md md:p-8">
  <!-- Stars -->
  <div class="mb-4 flex gap-1">
    {Array.from({ length: rating }).map(() => (
      <svg class="h-5 w-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Review Text -->
  <p class="text-neutral-700 leading-relaxed">{text}</p>

  <!-- Reviewer -->
  <div class="mt-6 flex items-center gap-3">
    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary font-heading text-sm font-bold text-primary">
      {name.split(" ").map((n) => n[0]).join("")}
    </div>
    <div>
      <p class="text-sm font-semibold text-neutral-900">{name}</p>
      <p class="text-xs text-neutral-500">{service}</p>
    </div>
  </div>
</div>
