---
interface Props {
  variant?: "primary" | "secondary" | "outline";
  href?: string;
  class?: string;
  size?: "sm" | "md" | "lg";
  booking?: boolean;
}

const {
  variant = "primary",
  href,
  class: className = "",
  size = "md",
  booking = false,
} = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center font-heading font-semibold rounded-full transition-all duration-300 cursor-pointer";

const sizeClasses = {
  sm: "px-5 py-2 text-sm",
  md: "px-7 py-3 text-sm",
  lg: "px-9 py-4 text-base",
};

const variantClasses = {
  primary: "bg-accent text-neutral-900 hover:bg-accent-dark shadow-md hover:shadow-lg",
  secondary: "bg-primary text-white hover:bg-primary-dark shadow-md hover:shadow-lg",
  outline: "border-2 border-primary text-primary hover:bg-primary hover:text-white",
};

const classes = `${baseClasses} ${sizeClasses[size]} ${variantClasses[variant]} ${className}`;
const Tag = href ? "a" : "button";
---

<Tag href={href} class={classes} {...booking ? { "data-booking": true } : {}}>
  <slot />
</Tag>
